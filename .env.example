# privacy-relayer — runtime configuration (docker compose reads this as env_file).
# Copy to `.env` and edit. All values map to the `serve` subcommand via clap env.

# ── Required ──────────────────────────────────────────────────────────────────
# Ethereum JSON-RPC (HTTP/HTTPS).
PRIVACYBTC_ETH_RPC_URL=https://your-rpc.example.com
# Chain id of the network above.
PRIVACYBTC_CHAIN_ID=1
# Relayer EOA private key (hex secp256k1). Pays gas for /submit_raw broadcasts.
# KEEP SECRET — do not commit your real .env.
PRIVACYBTC_RELAYER_PRIVATE_KEY=0xchange-me
# Primary contract address (factory or primary pool). /submit_raw can target any
# runtime-registered pool, but `serve` requires a contract to start.
PRIVACYBTC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the relayer (your web app).
PRIVACYBTC_CORS_ORIGINS=https://app.example.com

# ── Raw relay allowlist ───────────────────────────────────────────────────────
# /submit_raw is fail-closed unless BOTH lists are configured. Targets are
# 20-byte contract addresses; selectors are 4-byte function selectors.
# Example selectors:
#   transfer(bytes,uint256[3]) / burn(...) etc. should be generated from the
#   exact ABI used by your deployed contracts.
#PRIVACYBTC_SUBMIT_RAW_ALLOWED_TARGETS=0xPoolA,0xPoolB,0xCoordinator
#PRIVACYBTC_SUBMIT_RAW_ALLOWED_SELECTORS=0x12345678,0xabcdef01

# ── Gas tuning (optional) ─────────────────────────────────────────────────────
#PRIVACYBTC_GAS_PRICE_GWEI=1.0
#PRIVACYBTC_GAS_LIMIT_SHIELD=3000000
#PRIVACYBTC_GAS_LIMIT_TRANSFER=5000000
#PRIVACYBTC_GAS_LIMIT_UNSHIELD=3000000

# ── Optional integrations ─────────────────────────────────────────────────────
# Notify the indexer of broadcast tx hashes (faster note pickup).
#PRIVACYBTC_INDEXER_URL=http://indexer:8787
# Required when notifying a protected indexer after relayer broadcasts.
# Must match PRIVACYBTC_INDEXER_RELAYER_TOKEN on privacy-indexer.
#PRIVACYBTC_INDEXER_RELAYER_TOKEN=change-me-another-long-random-token

# Durable JSON snapshot for /swap/offers, /swap/accept, /swap/requests, and
# /swap/order. Required in production if LP swap matching is enabled.
# docker-compose.yml sets this to /data/swap-book.json on a persistent volume.
#PRIVACYBTC_SWAP_BOOK_PATH=/var/lib/privacy-relayer/swap-book.json

# Required to create or refresh /swap/offers. Keep this separate from user-facing
# routes: the LP bot sends it as the x-lp-offer-token header. When unset, offer
# creation is disabled (users may still read offers and submit accepts).
#PRIVACYBTC_LP_OFFER_TOKEN=change-me-long-random-token

# BTC payout is irreversible. When PRIVACYBTC_BTC_PAYOUT_WIF is set, configure an
# independent EVM RPC here and wait for this many confirmations before payout.
#PRIVACYBTC_ETH_RPC_FALLBACK_URLS=https://independent-evm-rpc.example.com
#PRIVACYBTC_BTC_PAYOUT_EVM_CONFIRMATIONS=12

# ── Layer 1 compliance screening (off-chain sanctions) ────────────────────────
# Screens the shield depositor / unshield recipient / issuer-mint beneficiary at
# the official relayer boundary. Pool contracts stay permissionless. OFF by default
# so dev/e2e flows are untouched. See docs_internal/.../compliance-implementation.md.
#
# Master switch. When false, all the vars below are ignored and no provider is called.
SCREENING_ENABLED=false
# Verdict combination: union | primary_fallback | layered (default: union).
#SCREENING_MODE=union
# Reject when no provider can return a verdict (recommended for production).
#SCREENING_FAIL_CLOSED=true
# Provider API keys — setting a key enables that provider; leaving it empty skips it.
#TRM_API_KEY=
#CHAINALYSIS_API_KEY=
# Per-provider request timeout (ms) and verdict cache TTL (seconds).
#SCREENING_TIMEOUT_MS=4000
#SCREENING_CACHE_TTL_SECS=600
# Endpoint overrides (for self-hosted gateways or a local mock in tests).
# Chainalysis defaults to the FREE Address Sanctions Screening API; swap to the
# paid KYT/entities endpoint if licensed.
#SCREENING_TRM_URL=https://api.trmlabs.com/public/v2/screening/addresses
#SCREENING_CHAINALYSIS_URL=https://public.chainalysis.com/api/v1/address

# Host bind/port for docker-compose. Default bind is loopback-only: put an
# authenticated/rate-limited reverse proxy in front of any endpoint the frontend
# must call. Do not expose the relayer port directly to the internet.
RELAYER_HOST_BIND=127.0.0.1
RELAYER_HOST_PORT=8790
